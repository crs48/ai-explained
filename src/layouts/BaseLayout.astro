---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AI Explained — how AI actually works, one scroll at a time",
  description = "An interactive, scroll-driven explainer for how AI models work. The first track: how a reasoning LLM thinks.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot name="header" />
    <main id="main">
      <slot />
    </main>
    <footer class="mx-auto max-w-3xl px-6 py-16 text-sm text-[var(--color-muted)]">
      <p>
        <strong class="text-[var(--color-fg)]">AI Explained</strong> — open source, built with
        Astro. Numbers you can type into (tokenizer, sampling) are computed live in your
        browser; illustrative visuals are labeled as such.
      </p>
    </footer>
    <style>
      .skip-link {
        position: absolute;
        left: -999px;
        top: 0;
        background: var(--color-surface-2);
        color: var(--color-fg);
        padding: 0.5rem 1rem;
        z-index: 100;
        border-radius: 0 0 6px 0;
      }
      .skip-link:focus {
        left: 0;
      }
    </style>
  </body>
</html>
