---
/** Renders a scene's interactive island by key, each lazily hydrated on scroll
 *  (`client:visible`). Literal tags are required so Astro can generate the
 *  hydration entrypoints. Add a case here when you add an island. */
import Tokenizer from "./islands/Tokenizer";
import EmbeddingSpace from "./islands/EmbeddingSpace";
import AttentionHeatmap from "./islands/AttentionHeatmap";
import SamplingPlayground from "./islands/SamplingPlayground";
import CoTToggle from "./islands/CoTToggle";
import TestTimeScaling from "./islands/TestTimeScaling";
import SelfRecursionLoop from "./islands/SelfRecursionLoop";
import TrainingReasoning from "./islands/TrainingReasoning";
import StrategyMorpher from "./islands/StrategyMorpher";
import EffortDial from "./islands/EffortDial";
import FaithfulnessCaveat from "./islands/FaithfulnessCaveat";
import LiveModel from "./islands/LiveModel";
import Alignment from "./islands/Alignment";
import DenoiseScrubber from "./islands/DenoiseScrubber";
import LatentSpace from "./islands/LatentSpace";
import CrossAttention from "./islands/CrossAttention";
import GuidanceScale from "./islands/GuidanceScale";
import DenoiserToggle from "./islands/DenoiserToggle";
import MoEBlockSwap from "./islands/MoEBlockSwap";
import TokenRouter from "./islands/TokenRouter";
import ActiveParams from "./islands/ActiveParams";
import LoadBalancer from "./islands/LoadBalancer";
import MoEMyths from "./islands/MoEMyths";
import NeuronForge from "./islands/NeuronForge";
import NetworkComposer from "./islands/NetworkComposer";
import LossMeter from "./islands/LossMeter";
import GradientBowl from "./islands/GradientBowl";
import BackpropGraph from "./islands/BackpropGraph";
import TinyTrainer from "./islands/TinyTrainer";
import OverfitLab from "./islands/OverfitLab";
import SuperpositionToy from "./islands/SuperpositionToy";
import InductionHead from "./islands/InductionHead";
import LogitLens from "./islands/LogitLens";
import FeatureSteering from "./islands/FeatureSteering";

interface Props {
  component: string;
}
const { component } = Astro.props;
---

{component === "Tokenizer" && <Tokenizer client:visible />}
{component === "EmbeddingSpace" && <EmbeddingSpace client:visible />}
{component === "AttentionHeatmap" && <AttentionHeatmap client:visible />}
{component === "SamplingPlayground" && <SamplingPlayground client:visible />}
{component === "CoTToggle" && <CoTToggle client:visible />}
{component === "TestTimeScaling" && <TestTimeScaling client:visible />}
{component === "SelfRecursionLoop" && <SelfRecursionLoop client:visible />}
{component === "TrainingReasoning" && <TrainingReasoning client:visible />}
{component === "StrategyMorpher" && <StrategyMorpher client:visible />}
{component === "EffortDial" && <EffortDial client:visible />}
{component === "FaithfulnessCaveat" && <FaithfulnessCaveat client:visible />}
{component === "LiveModel" && <LiveModel client:visible />}
{component === "Alignment" && <Alignment client:visible />}
{component === "DenoiseScrubber" && <DenoiseScrubber client:visible />}
{component === "LatentSpace" && <LatentSpace client:visible />}
{component === "CrossAttention" && <CrossAttention client:visible />}
{component === "GuidanceScale" && <GuidanceScale client:visible />}
{component === "DenoiserToggle" && <DenoiserToggle client:visible />}
{component === "MoEBlockSwap" && <MoEBlockSwap client:visible />}
{component === "TokenRouter" && <TokenRouter client:visible />}
{component === "ActiveParams" && <ActiveParams client:visible />}
{component === "LoadBalancer" && <LoadBalancer client:visible />}
{component === "MoEMyths" && <MoEMyths client:visible />}
{component === "NeuronForge" && <NeuronForge client:visible />}
{component === "NetworkComposer" && <NetworkComposer client:visible />}
{component === "LossMeter" && <LossMeter client:visible />}
{component === "GradientBowl" && <GradientBowl client:visible />}
{component === "BackpropGraph" && <BackpropGraph client:visible />}
{component === "TinyTrainer" && <TinyTrainer client:visible />}
{component === "OverfitLab" && <OverfitLab client:visible />}
{component === "SuperpositionToy" && <SuperpositionToy client:visible />}
{component === "InductionHead" && <InductionHead client:visible />}
{component === "LogitLens" && <LogitLens client:visible />}
{component === "FeatureSteering" && <FeatureSteering client:visible />}
