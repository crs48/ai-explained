---
import { getCollection } from "astro:content";

interface Props {
  current: string;
}
const { current } = Astro.props;

const tracks = (await getCollection("tracks")).sort((a, b) => a.data.order - b.data.order);
const base = import.meta.env.BASE_URL;
const join = (id: string) => `${base}${base.endsWith("/") ? "" : "/"}${id}`;
const repoUrl = "https://github.com/crs48/ai-explained";

/** At 5+ tracks a flat pill list stops scanning well — cluster by family.
 *  Families not listed here fall into a trailing "More" group. */
const GROUPS: { label: string; families: string[] }[] = [
  { label: "start here", families: ["foundations"] },
  { label: "language", families: ["language", "reasoning"] },
  { label: "image", families: ["diffusion"] },
  { label: "under the hood", families: ["interpretability"] },
];
const known = GROUPS.flatMap((g) => g.families);
const grouped = [
  ...GROUPS.map((g) => ({ label: g.label, tracks: tracks.filter((t) => g.families.includes(t.data.family)) })),
  { label: "more", tracks: tracks.filter((t) => !known.includes(t.data.family)) },
].filter((g) => g.tracks.length > 0);
---

<nav class="track-tabs" aria-label="Model tracks">
  <div class="brand">
    <span class="logo" aria-hidden="true"></span>
    <a href={base} class="brand-name">AI&nbsp;Explained</a>
  </div>
  <div class="tabs">
    {
      grouped.map((g) => (
        <div class="group" role="group" aria-label={g.label}>
          <span class="group-label">{g.label}</span>
          {g.tracks.map((t) =>
            t.data.available ? (
              <a
                href={join(t.id)}
                aria-current={t.id === current ? "page" : undefined}
                class:list={["tab", { active: t.id === current }]}
              >
                {t.data.title}
              </a>
            ) : (
              <span class="tab disabled" title="Coming soon">
                {t.data.title}
                <em>soon</em>
              </span>
            ),
          )}
        </div>
      ))
    }
  </div>
  <a href={repoUrl} class="gh-link" target="_blank" rel="noopener noreferrer" aria-label="View source on GitHub">
    <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
      <path
        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
      ></path>
    </svg>
  </a>
</nav>

<style>
  .track-tabs {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 1rem;
    flex-wrap: wrap;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
  }
  .logo {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid var(--color-unique-500);
    background: radial-gradient(circle at 50% 50%, var(--color-shared-500) 0 30%, transparent 32%);
  }
  .brand-name {
    color: var(--color-fg);
  }
  .tabs {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .group {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .group + .group {
    border-left: 1px solid var(--color-line);
    padding-left: 0.75rem;
  }
  .group-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-right: 0.15rem;
    white-space: nowrap;
  }
  @media (max-width: 700px) {
    .group-label {
      display: none;
    }
    .group + .group {
      border-left: none;
      padding-left: 0;
    }
  }
  .gh-link {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    color: var(--color-muted);
  }
  .gh-link:hover {
    color: var(--color-fg);
  }
  .tab {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.85rem;
    color: var(--color-muted);
    border: 1px solid transparent;
  }
  .tab.active {
    color: var(--color-fg);
    background: var(--color-surface-2);
    border-color: var(--color-line);
  }
  .tab:not(.disabled):hover {
    color: var(--color-fg);
  }
  .tab.disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  .tab em {
    font-style: normal;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-line);
    color: var(--color-fg);
    padding: 0.05rem 0.3rem;
    border-radius: 4px;
  }
</style>
