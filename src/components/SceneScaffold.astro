---
/** Sticky graphic panel + scrolling narration. The core scrollytelling unit.
 *  The `graphic` slot holds the interactive island; the default slot is MDX. */
interface Props {
  id: string;
  title: string;
  subtitle?: string;
  kind: "shared" | "unique";
  index: number;
  highlight?: boolean;
  hasGraphic?: boolean;
}
const { id, title, subtitle, kind, index, highlight = false, hasGraphic = true } = Astro.props;
---

<section class="scene" id={`scene-${id}`} data-scene-id={id} aria-labelledby={`h-${id}`}>
  <div class:list={["scene-grid", { "no-graphic": !hasGraphic }]}>
    {
      hasGraphic && (
        <div class="graphic">
          <div class:list={["graphic-card", { highlight }]}>
            <slot name="graphic" />
          </div>
        </div>
      )
    }
    <div class="narration">
      <div class="scene-head">
        <span class:list={["kind", kind, { highlight }]}>
          <span class="dot" aria-hidden="true"></span>
          {highlight ? "the one thing reasoning adds" : kind === "unique" ? "unique to this model" : "shared step"}
          {index > 0 && <span class="idx">· step {index}</span>}
        </span>
        <h2 id={`h-${id}`}>{title}</h2>
        {subtitle && <p class="subtitle">{subtitle}</p>}
      </div>
      <div class="prose">
        <slot />
      </div>
    </div>
  </div>
</section>

<style>
  .scene {
    scroll-margin-top: 90px;
    border-top: 1px solid var(--color-line);
  }
  .scene-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 78rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  @media (min-width: 900px) {
    .scene-grid:not(.no-graphic) {
      grid-template-columns: 1.05fr 0.95fr;
      gap: 3rem;
    }
    .scene-grid.no-graphic {
      max-width: 46rem;
    }
  }
  .graphic {
    order: -1;
  }
  @media (min-width: 900px) {
    .graphic {
      order: 1;
      position: sticky;
      top: 88px;
      align-self: start;
      height: min(74vh, 620px);
    }
  }
  .graphic-card {
    height: 100%;
    min-height: 320px;
    padding: 1.1rem;
    border-radius: 16px;
    border: 1px solid var(--color-line);
    background: linear-gradient(180deg, var(--color-surface-2), var(--color-surface));
    box-shadow: 0 10px 40px -20px rgba(0, 0, 0, 0.8);
  }
  .graphic-card.highlight {
    border-color: color-mix(in oklab, var(--color-unique-500) 55%, var(--color-line));
    box-shadow: 0 0 0 1px color-mix(in oklab, var(--color-unique-500) 30%, transparent),
      0 10px 50px -18px color-mix(in oklab, var(--color-unique-500) 45%, transparent);
  }
  .narration {
    padding-block: 1rem 4rem;
  }
  .scene-head {
    margin-bottom: 1rem;
  }
  .kind {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-shared-400);
  }
  .kind .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-shared-500);
  }
  .kind.unique {
    color: var(--color-unique-400);
  }
  .kind.unique .dot {
    background: var(--color-unique-500);
  }
  .kind .idx {
    color: var(--color-muted);
    letter-spacing: 0;
    text-transform: none;
  }
  h2 {
    margin-top: 0.35rem;
    font-size: clamp(1.5rem, 1rem + 1.6vw, 2.1rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .subtitle {
    margin-top: 0.5rem;
    color: var(--color-muted);
    font-size: 1.05rem;
  }
</style>
