---
/** Base-path-aware link from one scene's narration to another track.
 *  (Plain markdown links can't know BASE_URL; this can.) */
interface Props {
  track: string;
}
const { track } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = `${base}${base.endsWith("/") ? "" : "/"}${track}`;
---

<a href={href}><slot /></a>
